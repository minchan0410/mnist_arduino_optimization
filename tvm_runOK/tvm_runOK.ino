void setup() {
  Serial.begin(9600);
  while (!Serial);
  Serial.println("TVM inference ready");
}

void loop() {
  // 입력 복사
  memcpy(g_input, x_test, kInputSize);

  // 추론 실행
  unsigned long t_start = micros();
  int ret = tvmgen_default_run(&tvm_inputs, &tvm_outputs);
  unsigned long t_end = micros();

  if (ret != 0) {
    Serial.print("Inference failed: ");
    Serial.println(ret);
    delay(1000);
    return;
  }

  // 결과 분석
  int predicted_class = 0;
  int8_t max_score = -128;
  for (int i = 0; i < kNumClasses; i++) {
    if (g_output[i] > max_score) {
      predicted_class = i;
      max_score = g_output[i];
    }
  }

  Serial.print("Predicted: ");
  Serial.print(predicted_class);
  Serial.print("  GT: ");
  Serial.print(kGroundTruth);
  Serial.print("  Inference: ");
  Serial.print(t_end - t_start);
  Serial.println(" us");

  delay(1000);
}
