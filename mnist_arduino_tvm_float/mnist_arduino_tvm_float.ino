void setup() {
  Serial.begin(9600);
  while (!Serial);

  // TVM 런타임 초기화
  TVMInitialize();
  Serial.println("TVM inference ready");
}

void loop() {
  // 입력 복사
  memcpy(g_input, x_test, kInputSize * sizeof(float));

  
  unsigned long t0 = micros();
  TVMExecute(g_input, g_output);
  unsigned long t1 = micros();
  
  // argmax
  int pred = 0;
  float best = -1.0f;
  for (int i = 0; i < kNumClasses; i++) {
    if (g_output[i] > best) {
      pred = i;
      best = g_output[i];
    }
  }


  Serial.print("Predicted: ");
  Serial.print(pred);
  Serial.print("  GT: ");
  Serial.print(kGroundTruth);
  Serial.print("  Time: ");
  Serial.print(t1 - t0);
  Serial.println(" us");

  delay(1000);
}
